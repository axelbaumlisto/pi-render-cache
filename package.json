{
  "name": "pi-render-cache",
  "version": "1.0.0",
  "description": "Cuts pi coding-agent TUI CPU during streaming from ~105% of a core to ~10-16% by memoizing Intl.Segmenter (ICU grapheme segmentation) and incrementally caching Markdown.render",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "performance",
    "tui",
    "markdown",
    "intl-segmenter"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/axelbaumlisto/pi-render-cache.git"
  },
  "files": [
    "extensions",
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "test": "node --test tests/",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm pack --dry-run",
    "prepublishOnly": "npm run check"
  }
}
